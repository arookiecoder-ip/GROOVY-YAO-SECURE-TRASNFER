{
  "name": "groovy-yao",
  "version": "0.1.0",
  "description": "Personal secure real-time file transfer system",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "node src/db/migrate.js",
